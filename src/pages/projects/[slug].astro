---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sectionUrl, site } from '../../data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`${project.data.title} | ${site.name}`}
  description={project.data.description}
>
  <article class="relative py-28 sm:py-32">
    <div class="absolute inset-x-0 top-0 h-72 bg-gradient-to-b from-cyan-500/10 via-emerald-500/5 to-transparent" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a
        href={sectionUrl('projects')}
        class="inline-flex items-center gap-2 text-sm font-medium text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-primary))] transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to projects
      </a>

      <header class="glass rounded-2xl p-6 sm:p-8 mb-8">
        <div class="flex flex-wrap gap-2 mb-5">
          {project.data.techStack.map((tech) => (
            <span class="tag">{tech}</span>
          ))}
        </div>

        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight gradient-text mb-4">
          {project.data.title}
        </h1>
        <p class="text-base sm:text-lg text-[rgb(var(--color-text-secondary))] leading-relaxed mb-6">
          {project.data.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <span>View Code</span>
          </a>
          {project.data.liveUrl && (
            <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-outline">
              Live Demo
            </a>
          )}
        </div>
      </header>

      <div class="mdx-content glass rounded-2xl p-6 sm:p-8">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>


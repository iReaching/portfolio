---

<section id="contact" class="relative py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-[rgb(var(--color-primary))] mb-3 animate-on-scroll">Get in touch</p>
      <h2 class="section-heading gradient-text animate-on-scroll">Contact Me</h2>
      <p class="section-subheading animate-on-scroll">
        Interested in working together? Reach out through email, GitHub, or LinkedIn.
      </p>
    </div>

    <div class="grid lg:grid-cols-1 gap-8 max-w-5xl mx-auto">
      <div class="space-y-4 animate-on-scroll">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('mailto') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            class="glass glass-hover rounded-2xl p-6 flex items-center gap-5 group"
            aria-label={`Contact via ${link.label}`}
          >
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${link.color} flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-300`}>
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={link.icon} />
              </svg>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-[rgb(var(--color-text-secondary))] uppercase tracking-wide">{link.label}</p>
              <p class="text-base font-medium group-hover:text-[rgb(var(--color-primary))] transition-colors break-words">{link.value}</p>
            </div>
            <svg class="w-5 h-5 ml-auto shrink-0 text-[rgb(var(--color-text-secondary))] group-hover:text-[rgb(var(--color-primary))] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        ))}
      </div>

      
    </div>
  </div>
</section>

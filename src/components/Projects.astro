---
import { getCollection } from 'astro:content';
import { assetUrl } from '../data/site';

interface Project {
  title: string;
  description: string;
  techStack: string[];
  githubUrl: string;
  liveUrl?: string;
  image?: string;
  featured?: boolean;
  slug?: string;
}

let projects: Project[] = [];
try {
  const projectEntries = await getCollection('projects');
  projects = projectEntries
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
      title: entry.data.title,
      description: entry.data.description,
      techStack: entry.data.techStack,
      githubUrl: entry.data.githubUrl,
      liveUrl: entry.data.liveUrl,
      image: entry.data.image,
      featured: entry.data.featured,
      slug: entry.id,
    }));
} catch {
  projects = [];
}

if (projects.length === 0) {
  projects = [
    {
      title: 'Portfolio Website',
      description: 'A modern, responsive portfolio website built with Astro, Tailwind CSS, TypeScript, and MDX.',
      techStack: ['Astro', 'Tailwind CSS', 'TypeScript', 'MDX'],
      githubUrl: 'https://github.com/yourusername/portfolio',
      liveUrl: 'https://yourusername.github.io',
      featured: true,
    },
  ];
}
---

<section id="projects" class="relative py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-[rgb(var(--color-primary))] mb-3 animate-on-scroll">My work</p>
      <h2 class="section-heading gradient-text animate-on-scroll">Featured Projects</h2>
      <p class="section-subheading animate-on-scroll">
        A selection of projects showcasing development, AI, and practical technology skills.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <article class="glass glass-hover rounded-2xl overflow-hidden group animate-on-scroll">
          <div class="relative h-48 bg-gradient-to-br from-cyan-500/20 via-emerald-500/20 to-amber-500/20 flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-[linear-gradient(rgba(34,211,238,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(34,211,238,0.05)_1px,transparent_1px)] bg-[size:2rem_2rem]" aria-hidden="true"></div>
            <div class="relative text-center p-6">
              <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-lg font-bold text-cyan-100 opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300">
                {project.title.split(' ').map((word) => word[0]).join('').slice(0, 2).toUpperCase()}
              </div>
              {project.featured && (
                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-cyan-500/15 text-cyan-200 border border-cyan-500/30">
                  Featured
                </span>
              )}
            </div>
          </div>

          <div class="p-6">
            <h3 class="text-lg font-bold mb-2 group-hover:text-[rgb(var(--color-primary))] transition-colors">
              {project.slug ? (
                <a href={assetUrl(`projects/${project.slug}/`)} class="hover:underline underline-offset-4">
                  {project.title}
                </a>
              ) : project.title}
            </h3>
            <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-4 line-clamp-3 leading-relaxed">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-5">
              {project.techStack.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-4 border-t border-[rgb(var(--color-border)_/_0.3)]">
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-sm text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-primary))] transition-colors"
                aria-label={`View ${project.title} source code on GitHub`}
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                Code
              </a>
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 text-sm text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-accent))] transition-colors"
                  aria-label={`View ${project.title} live demo`}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Demo
                </a>
              )}
              {project.slug && (
                <a
                  href={assetUrl(`projects/${project.slug}/`)}
                  class="sm:ml-auto flex items-center gap-1.5 text-sm text-[rgb(var(--color-primary))] hover:underline underline-offset-4 transition-colors"
                >
                  Details
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
